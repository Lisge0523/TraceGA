    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-esbuild": "^6.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
