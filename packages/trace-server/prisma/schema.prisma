generator client {
  provider = "prisma-client-js"
  output   = "../dist/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model event_definition {
  id           BigInt    @id @default(autoincrement())
  project_id   String    @db.VarChar(64)
  event_name   String    @db.VarChar(128)
  event_type   String?   @db.VarChar(64)
  event_desc   String?   @db.VarChar(255)
  param_schema Json?
  status       Int?      @default(1) @db.TinyInt
  created_at   DateTime? @default(now()) @db.DateTime(0)
  updated_at   DateTime? @default(now()) @updatedAt @db.DateTime(0)
}

model event_daily_stat {
  id         BigInt    @id @default(autoincrement())
  stat_date  DateTime  @db.Date
  project_id String    @db.VarChar(64)
  event_name String    @db.VarChar(128)
  pv         BigInt?   @default(0)
  uv         BigInt?   @default(0)
  created_at DateTime? @default(now()) @db.DateTime(0)

  @@index([project_id, event_name, stat_date], map: "idx_daily_project_event_date")
}

model event_log {
  id            BigInt    @id @default(autoincrement())
  project_id    String    @db.VarChar(64)
  event_name    String    @db.VarChar(128)
  event_type    String?   @db.VarChar(64)
  occurred_at   DateTime? @db.DateTime(0)
  uid           String?   @db.VarChar(128)
  session_id    String?   @db.VarChar(128)
  page_url      String?   @db.VarChar(512)
  event_params  Json?
  common_params Json?
  user_agent    String?   @db.Text
  ip            String?   @db.VarChar(64)
  created_at    DateTime? @default(now()) @db.DateTime(0)

  @@index([page_url], map: "idx_event_page_url")
  @@index([project_id, event_name, created_at], map: "idx_event_project_name_time")
  @@index([project_id, event_name, uid, created_at], map: "idx_event_project_name_uid_time")
  @@index([project_id, occurred_at], map: "idx_event_project_occurred_at")
}

model project {
  id           BigInt    @id @default(autoincrement())
  project_id   String    @unique(map: "project_id") @db.VarChar(64)
  project_name String    @db.VarChar(128)
  owner        String?   @db.VarChar(64)
  created_at   DateTime? @default(now()) @db.DateTime(0)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ai_call_log {
  id                BigInt    @id @default(autoincrement())
  project_id        String    @db.VarChar(64)
  trace_id          String?   @db.VarChar(64)
  feature           String    @db.VarChar(32)
  model             String    @db.VarChar(32)
  system_prompt     String?   @db.Text
  user_prompt       String?   @db.Text
  response_text     String?   @db.Text
  prompt_tokens     Int?
  completion_tokens Int?
  total_tokens      Int?
  latency_ms        Int?
  status            String    @db.VarChar(16)
  error_message     String?   @db.Text
  created_at        DateTime? @default(now()) @db.DateTime(0)

  @@index([project_id, feature, created_at], map: "idx_ai_log_project_feature_time")
  @@index([trace_id], map: "idx_ai_log_trace_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ai_daily_report {
  id             BigInt    @id @default(autoincrement())
  project_id     String    @db.VarChar(64)
  stat_date      DateTime  @db.Date
  stats_json     Json?
  report_text    String?   @db.Text
  prompt_version String?   @db.VarChar(32)
  model          String?   @db.VarChar(32)
  tokens_used    Int?
  created_at     DateTime? @default(now()) @db.DateTime(0)
  updated_at     DateTime? @default(now()) @db.DateTime(0)

  @@unique([project_id, stat_date], map: "uk_project_date")
}

model user {
  id            BigInt    @id @default(autoincrement())
  username      String    @db.VarChar(64)
  email         String    @unique(map: "uk_email") @db.VarChar(128)
  phone         String    @unique(map: "uk_phone") @db.VarChar(32)
  password_hash String    @db.VarChar(255)
  role          String?   @default("admin") @db.VarChar(32)
  avatar        String?   @db.VarChar(512)
  status        Int?      @default(1) @db.TinyInt
  last_login_at DateTime? @db.DateTime(0)
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.DateTime(0)
}

model alarm {
  id           BigInt    @id @default(autoincrement())
  project_id   String    @db.VarChar(64)
  event_name   String    @db.VarChar(128)
  threshold    Decimal?  @db.Decimal(10, 2)
  operator     String?   @db.VarChar(16)
  notify_type  String?   @db.VarChar(32)
  status       Int?      @default(1) @db.TinyInt
  created_at   DateTime? @default(now()) @db.DateTime(0)
  updated_at   DateTime? @default(now()) @updatedAt @db.DateTime(0)
}
